# App
APP_NAME=DataWhisperer
APP_ENV=dev
LOG_LEVEL=INFO

# MySQL example:
# mysql+pymysql://user:password@127.0.0.1:3306/datawhisperer_demo?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/datawhisperer_demo?charset=utf8mb4
QUERY_TIMEOUT_SECONDS=20
MAX_QUERY_ROWS=100

# OpenAI-compatible LLM.
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=replace-me
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.1

# DashScope unified config.
# Keep the real key only in local .env. Never commit it to GitHub.
DASHSCOPE_API_KEY=replace-me
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSION=1024

# Embedding provider.
# dashscope: use DASHSCOPE_EMBEDDING_MODEL.
# hashing: use the local deterministic fallback vectorizer.
EMBEDDING_PROVIDER=dashscope
EMBEDDING_AUTO_FALLBACK=true

# RAG metric retrieval.
# local: use the built-in hybrid keyword + n-gram retriever.
# milvus: use Milvus vector search first, then fall back to local retrieval when unavailable.
METRIC_RETRIEVAL_PROVIDER=local
MILVUS_URI=http://127.0.0.1:19530
MILVUS_METRIC_COLLECTION=datawhisperer_metrics
MILVUS_EMBEDDING_DIM=1024
MILVUS_AUTO_FALLBACK=true
